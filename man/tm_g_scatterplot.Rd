        ),
        teal.picks::values()
      ),
      size_by = teal.picks::picks(
        datasets("CO2"),
        teal.picks::variables(choices = c("conc", "uptake"), selected = "uptake"),
        teal.picks::values()
      ),
      row_facet = teal.picks::picks(
        datasets("CO2"),
        teal.picks::variables(
          choices = c("Plant", "Type", "Treatment"),
